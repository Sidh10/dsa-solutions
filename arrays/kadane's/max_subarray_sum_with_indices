def max_subarray_sum(arr):
    if not arr:
        return 0
    current_sum = arr[0]
    best_sum = arr[0]
    temp_start = 0
    start = 0
    end = 0
    for i in range(1,len(arr)):
        if arr[i]>current_sum + arr[i]:
            current_sum = arr[i]
            temp_start = i
        else:
            current_sum = current_sum + arr[i]
        if current_sum>best_sum:
            best_sum = current_sum
            start = temp_start
            end =  i   
    return(best_sum,start, end)